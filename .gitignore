# KI-Produkt-Faktencheck .gitignore

# ============================================================
# SECRETS & API KEYS
# ============================================================
.env
*.key
secrets/
credentials/

# ============================================================
# DATA FILES (enthalten vertrauliche/proprietäre Inhalte)
# ============================================================

# Input-Daten (AI-Responses)
Responses-*.csv
*-Responses.csv
responses_*.csv

# Extracted Claims
claims_*.csv
!claims_sample.csv  # Ausnahme: Sample-Daten für Demo

# Canonical Claims
claims_canonical.csv
claim_clusters.csv

# Fact-Checked Results
claims_factchecked*.csv
factcheck_*.csv

# Interim/Test Data
test_*.csv
pilot_*.csv
sample_*.csv
short_answers.csv

# ============================================================
# CACHE & TEMPORARY FILES
# ============================================================

# Embedding Cache (enthält prozessierte Daten)
embeddings_cache.pkl
*.pkl
*.pickle

# Logs
*.log
*.jsonl
extraction_errors.jsonl
dedup_log.txt

# Temp
*.tmp
*.temp
.DS_Store

# ============================================================
# PYTHON
# ============================================================

# Virtual Environments
venv/
venv_*/
env/
ENV/
.venv

# Python Cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Distribution / Packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Unit test / coverage
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# ============================================================
# IDE / EDITORS
# ============================================================

# VSCode
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# ============================================================
# OS
# ============================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory
.Trash-*

# ============================================================
# PROJECT-SPECIFIC
# ============================================================

# Google Drive Desktop sync files
.tmp.driveupload/
.tmp.drivedownload/
~$*

# Backup files
*.bak
*.backup
*~

# Output directories
output/
results/
exports/

# ============================================================
# KEEP THESE (explicitly not ignored)
# ============================================================
# Dokumentation (keine Secrets)
!README.md
!ARCHITEKTUR.md
!QUICK_START_TILL.md
!ENTWICKLER_DEEP_DIVE.md
!RESULTS_SUMMARY_MONTAG.md
!FACTCHECK_V2_VERGLEICH.md

# Python-Scripts (Code ohne Secrets)
!*.py

# Config-Templates (ohne echte Keys)
!.env.example
!requirements.txt

# Sample-Daten (anonymisiert, klein)
!data/samples/

# Backup-Ordner (alte Versionen)
files*/
files (*/
files*.zip
